{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/catalog/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/catalog"
          },
          {
            "ResponseHeader": "X-Gateway",
            "Set": "YARP"
          }
        ]
      },
      "basket-route": {
        "ClusterId": "basket-cluster",
        "Match": {
          "Path": "/cart/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "basket/{**catch-all}"
          },
          {
            "ResponseHeader": "X-Gateway",
            "Set": "YARP"
          }
        ]
      },
      "ordering-route": {
        "ClusterId": "ordering-cluster",
        "Match": {
          "Path": "/orders/{**catch-all}"
        },
        "Transforms": [
          {
            "ResponseHeader": "X-Gateway",
            "Set": "YARP"
          }
        ]
      },
      "discount-route": {
        "ClusterId": "discount-cluster",
        "Match": {
          "Path": "/discounts/{**catch-all}"
        },
        "Transforms": [
          {
            "ResponseHeader": "X-Gateway",
            "Set": "YARP"
          }
        ]
      },
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "ResponseHeader": "X-Gateway",
            "Set": "YARP"
          }
        ]
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/payments/{**catch-all}"
        },
        "Transforms": [
          {
            "ResponseHeader": "X-Gateway",
            "Set": "YARP"
          }
        ]
      },
      "payment-webhook-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/webhooks/{**catch-all}"
        },
        "Transforms": [
          {
            "ResponseHeader": "X-Gateway",
            "Set": "YARP"
          }
        ]
      }
    },
    "Clusters": {
      "catalog-cluster": {
        "Destinations": {
          "catalog-destination": {
            "Address": "https://localhost:7002/"
          }
        }
      },
      "basket-cluster": {
        "Destinations": {
          "basket-destination": {
            "Address": "https://localhost:7003/"
          }
        }
      },
      "ordering-cluster": {
        "Destinations": {
          "ordering-destination": {
            "Address": "https://localhost:7005/"
          }
        }
      },
      "discount-cluster": {
        "Destinations": {
          "discount-destination": {
            "Address": "https://localhost:7006/"
          }
        }
      },
      "identity-cluster": {
        "Destinations": {
          "identity-destination": {
            "Address": "https://localhost:7004/"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment-destination": {
            "Address": "https://localhost:7007/"
          }
        }
      }
    }
  }
}
