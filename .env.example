# MicroShop local production-like environment sample.
# Copy this file to .env.local-prod and replace every CHANGEME value before running compose.local-prod.yml.

MICROSHOP_POSTGRES_PASSWORD=CHANGEME-postgres-password
MICROSHOP_RABBITMQ_PASSWORD=CHANGEME-rabbitmq-password
MICROSHOP_MONGO_PASSWORD=CHANGEME-mongodb-password

# Must be at least 32 bytes because IdentityService validates JWT signing keys on startup.
MICROSHOP_JWT_SECRET_KEY=CHANGEME-jwt-secret-key-at-least-32-bytes-long

# Used by PaymentService webhook HMAC validation.
MICROSHOP_PAYMENT_WEBHOOK_SECRET=CHANGEME-payment-webhook-secret-at-least-32-bytes

# Keep this aligned with MICROSHOP_MONGO_PASSWORD.
# URL-encode special characters if the password contains symbols reserved by MongoDB URLs.
MICROSHOP_MONGODB_CONNECTION_STRING=mongodb://microshop:CHANGEME-mongodb-password@mongodb:27017/?authSource=admin
