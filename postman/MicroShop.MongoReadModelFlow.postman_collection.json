{
  "info": {
    "name": "MicroShop Mongo Read Model Flow",
    "description": "Lesson 26 MongoDB read model smoke tests for OrderQueryService.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "orderQueryBaseUrl",
      "value": "https://localhost:7008"
    },
    {
      "key": "gatewayBaseUrl",
      "value": "https://localhost:7001"
    },
    {
      "key": "orderId",
      "value": "11111111-1111-1111-1111-111111111111"
    },
    {
      "key": "customerId",
      "value": "22222222-2222-2222-2222-222222222222"
    }
  ],
  "item": [
    {
      "name": "01 - Service health",
      "request": {
        "method": "GET",
        "url": "{{orderQueryBaseUrl}}/alive"
      }
    },
    {
      "name": "02 - Debug upsert order summary",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"customerId\": \"{{customerId}}\",\n  \"customerName\": \"Demo Customer\",\n  \"status\": \"Created\",\n  \"totalAmount\": 1977.30,\n  \"currency\": \"VND\",\n  \"itemCount\": 1,\n  \"items\": [\n    {\n      \"productId\": \"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa\",\n      \"productName\": \"MacBook Pro\",\n      \"quantity\": 1,\n      \"unitPrice\": 1977.30\n    }\n  ]\n}"
        },
        "url": "{{orderQueryBaseUrl}}/debug/order-summaries"
      }
    },
    {
      "name": "03 - Get latest order summaries",
      "request": {
        "method": "GET",
        "url": "{{orderQueryBaseUrl}}/order-summaries?limit=20"
      }
    },
    {
      "name": "04 - Get order summary by id",
      "request": {
        "method": "GET",
        "url": "{{orderQueryBaseUrl}}/order-summaries/{{orderId}}"
      }
    },
    {
      "name": "05 - Upsert same order as paid",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"orderId\": \"{{orderId}}\",\n  \"customerId\": \"{{customerId}}\",\n  \"customerName\": \"Demo Customer\",\n  \"status\": \"Paid\",\n  \"totalAmount\": 1977.30,\n  \"currency\": \"VND\",\n  \"itemCount\": 1,\n  \"items\": [\n    {\n      \"productId\": \"aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa\",\n      \"productName\": \"MacBook Pro\",\n      \"quantity\": 1,\n      \"unitPrice\": 1977.30\n    }\n  ]\n}"
        },
        "url": "{{orderQueryBaseUrl}}/debug/order-summaries"
      }
    },
    {
      "name": "06 - Get missing order summary",
      "request": {
        "method": "GET",
        "url": "{{orderQueryBaseUrl}}/order-summaries/99999999-9999-9999-9999-999999999999"
      }
    },
    {
      "name": "07 - Gateway get latest order summaries",
      "request": {
        "method": "GET",
        "url": "{{gatewayBaseUrl}}/order-summaries?limit=20"
      }
    }
  ]
}
