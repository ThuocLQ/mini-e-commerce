{
  "info": {
    "name": "MicroShop Operational Visibility Flow",
    "description": "Lesson 28 health and operational visibility smoke checks for OrderQueryService, ApiGateway, and order summary routing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "orderQueryBaseUrl",
      "value": "http://localhost:5088"
    },
    {
      "key": "gatewayBaseUrl",
      "value": "http://localhost:5027"
    },
    {
      "key": "orderId",
      "value": "11111111-1111-1111-1111-111111111111"
    }
  ],
  "item": [
    {
      "name": "01 - OrderQuery health",
      "request": {
        "method": "GET",
        "url": "{{orderQueryBaseUrl}}/health"
      }
    },
    {
      "name": "02 - OrderQuery alive",
      "request": {
        "method": "GET",
        "url": "{{orderQueryBaseUrl}}/alive"
      }
    },
    {
      "name": "03 - ApiGateway health",
      "request": {
        "method": "GET",
        "url": "{{gatewayBaseUrl}}/health"
      }
    },
    {
      "name": "04 - Gateway get order summaries",
      "request": {
        "method": "GET",
        "url": "{{gatewayBaseUrl}}/order-summaries?limit=20"
      }
    },
    {
      "name": "05 - Gateway get order summary by id",
      "request": {
        "method": "GET",
        "url": "{{gatewayBaseUrl}}/order-summaries/{{orderId}}"
      }
    }
  ]
}
