{
  "info": {
    "name": "MicroShop Foundation Checkpoint",
    "description": "Day 30 foundation checkpoint requests. Lite mode uses OrderQueryService directly. Gateway requests are optional and require api-gateway to be running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "gateway_url",
      "value": "http://localhost:5027"
    },
    {
      "key": "order_query_url",
      "value": "http://localhost:5088"
    },
    {
      "key": "orderId",
      "value": "11111111-1111-1111-1111-111111111111"
    }
  ],
  "item": [
    {
      "name": "Lite - 01 - OrderQuery health",
      "request": {
        "method": "GET",
        "url": "{{order_query_url}}/health"
      }
    },
    {
      "name": "Lite - 02 - Order summaries",
      "request": {
        "method": "GET",
        "url": "{{order_query_url}}/order-summaries?limit=20"
      }
    },
    {
      "name": "Lite - 03 - Order summary by id",
      "request": {
        "method": "GET",
        "url": "{{order_query_url}}/order-summaries/{{orderId}}"
      }
    },
    {
      "name": "Gateway Optional - 04 - Gateway health",
      "request": {
        "method": "GET",
        "url": "{{gateway_url}}/health"
      }
    },
    {
      "name": "Gateway Optional - 05 - Gateway order summaries",
      "request": {
        "method": "GET",
        "url": "{{gateway_url}}/order-summaries?limit=20"
      }
    },
    {
      "name": "Gateway Optional - 06 - Gateway order summary by id",
      "request": {
        "method": "GET",
        "url": "{{gateway_url}}/order-summaries/{{orderId}}"
      }
    }
  ]
}
