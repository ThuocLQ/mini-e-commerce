{
  "info": {
    "name": "MicroShop - Identity Flow",
    "_postman_id": "4d1ca541-2238-47aa-941f-909f80e299e9",
    "description": "IdentityService flow through ApiGateway: login, call /auth/me, invalid login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "gatewayBaseUrl",
      "value": "https://localhost:7001"
    },
    {
      "key": "accessToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "01 - Login as admin",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Login succeeds', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const result = pm.response.json();",
              "pm.collectionVariables.set('accessToken', result.accessToken);",
              "pm.test('Access token returned', function () {",
              "  pm.expect(result.accessToken).to.be.a('string').and.not.empty;",
              "  pm.expect(result.tokenType).to.eql('Bearer');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userName\": \"admin\",\n  \"password\": \"Admin@123\"\n}"
        },
        "url": {
          "raw": "{{gatewayBaseUrl}}/auth/login",
          "host": [
            "{{gatewayBaseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "02 - Get current user",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Me succeeds', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const user = pm.response.json();",
              "pm.test('Admin user returned', function () {",
              "  pm.expect(user.userName).to.eql('admin');",
              "  pm.expect(user.role).to.eql('Admin');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": {
          "raw": "{{gatewayBaseUrl}}/auth/me",
          "host": [
            "{{gatewayBaseUrl}}"
          ],
          "path": [
            "auth",
            "me"
          ]
        }
      }
    },
    {
      "name": "03 - Invalid login returns 401",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Invalid login is unauthorized', function () {",
              "  pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userName\": \"admin\",\n  \"password\": \"wrong-password\"\n}"
        },
        "url": {
          "raw": "{{gatewayBaseUrl}}/auth/login",
          "host": [
            "{{gatewayBaseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      }
    }
  ]
}
